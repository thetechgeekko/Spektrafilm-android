<?xml version="1.0" encoding="utf-8"?>
<!--
  SpectraFilm for Android. GPLv3.
  Adaptive-icon foreground: a 35mm film frame with sprocket holes and a
  spectral (rainbow) strip across the exposed frame. Drawn inside the 108x108
  viewport, kept within the ~66dp adaptive safe zone (margins ~21).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Film body (rounded dark strip) -->
    <path
        android:fillColor="#1C2530"
        android:pathData="M28,24 L80,24 A6,6 0 0 1 86,30 L86,78 A6,6 0 0 1 80,84 L28,84 A6,6 0 0 1 22,78 L22,30 A6,6 0 0 1 28,24 Z" />

    <!-- Spectral strip: 6 vertical bands forming the exposed frame -->
    <path android:fillColor="#FF3B30" android:pathData="M35,38 h6 v32 h-6 Z" />
    <path android:fillColor="#FF9500" android:pathData="M41,38 h6 v32 h-6 Z" />
    <path android:fillColor="#FFCC00" android:pathData="M47,38 h6 v32 h-6 Z" />
    <path android:fillColor="#34C759" android:pathData="M53,38 h6 v32 h-6 Z" />
    <path android:fillColor="#007AFF" android:pathData="M59,38 h6 v32 h-6 Z" />
    <path android:fillColor="#AF52DE" android:pathData="M65,38 h6 v32 h-6 Z" />

    <!-- Frame outline around the spectral window -->
    <path
        android:strokeColor="#0E141B"
        android:strokeWidth="2"
        android:fillColor="#00000000"
        android:pathData="M35,38 h36 v32 h-36 Z" />

    <!-- Sprocket holes (top row) -->
    <path android:fillColor="#0E141B" android:pathData="M27,29 h5 v5 h-5 Z" />
    <path android:fillColor="#0E141B" android:pathData="M36,29 h5 v5 h-5 Z" />
    <path android:fillColor="#0E141B" android:pathData="M45,29 h5 v5 h-5 Z" />
    <path android:fillColor="#0E141B" android:pathData="M54,29 h5 v5 h-5 Z" />
    <path android:fillColor="#0E141B" android:pathData="M63,29 h5 v5 h-5 Z" />
    <path android:fillColor="#0E141B" android:pathData="M72,29 h5 v5 h-5 Z" />

    <!-- Sprocket holes (bottom row) -->
    <path android:fillColor="#0E141B" android:pathData="M27,74 h5 v5 h-5 Z" />
    <path android:fillColor="#0E141B" android:pathData="M36,74 h5 v5 h-5 Z" />
    <path android:fillColor="#0E141B" android:pathData="M45,74 h5 v5 h-5 Z" />
    <path android:fillColor="#0E141B" android:pathData="M54,74 h5 v5 h-5 Z" />
    <path android:fillColor="#0E141B" android:pathData="M63,74 h5 v5 h-5 Z" />
    <path android:fillColor="#0E141B" android:pathData="M72,74 h5 v5 h-5 Z" />
</vector>
