{
  "version": 2,
  "_comment": "Built-in look presets. Authored against the nested SpektraParams schema and mapped by BuiltInPresets.applyParams. Only ENGINE-HONORED fields are set: grain is fully tunable (and per-stock here, since the engine otherwise gives every stock Portra-400 grain); halation uses halationAmount/scatterAmount/boost (halationStrength + halationFirstSigmaUm are baked from each profile's use/antihalation tags and ignored); DIR couplers use amount/inhibition/diffusion (gamma matrices are baked per stock); diffusionFilter geometry is honored but filterFamily is fixed to black_pro_mist by the C API. Grain/halation are um-based and so look stronger at full-res/zoom than in the fit preview.",
  "presets": [
    {
      "id": "portra160_endura_softlight",
      "name": "Portra 160 — Soft Light Portrait",
      "group": "Portrait",
      "description": "The finest-grain, lowest-contrast Portra on low-contrast Endura. Gentle, luminous, true skin.",
      "params": {
        "filmProfile": "kodak_portra_160",
        "printProfile": "kodak_portra_endura",
        "io": { "scanFilm": false, "outputColorSpace": "SRGB" },
        "camera": { "exposureCompensationEv": 0.3, "autoExposure": false },
        "filmRender": {
          "densityCurveGamma": 0.94,
          "grain": {
            "active": true, "sublayersActive": true, "blur": 0.55,
            "agxParticleScale": [0.65, 0.85, 1.7], "agxParticleScaleLayers": [2.5, 1.0, 0.5],
            "uniformity": [0.98, 0.98, 0.99], "blurDyeCloudsUm": 0.9, "microStructure": [0.15, 30], "nSubLayers": 1
          },
          "halation": {
            "active": true, "halationAmount": 0.85, "scatterAmount": 0.9,
            "halationNBounces": 3, "halationBounceDecay": 0.5
          },
          "dirCouplers": {
            "active": true, "amount": 1.0, "inhibitionSamelayer": 1.0, "inhibitionInterlayer": 1.0,
            "diffusionSizeUm": 20.0, "diffusionTailUm": 200.0, "diffusionTailWeight": 0.06
          }
        },
        "scanner": { "unsharpMask": [0.4, 0.7] }
      }
    },
